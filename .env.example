# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=          # Bot token from @BotFather
TELEGRAM_BOT_USERNAME=       # e.g. EatPulseBot (used by Login Widget)

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=              # sk-...

# ── Database ──────────────────────────────────────────────────────────────────
# Points to PgBouncer on localhost in production; direct postgres in dev
DATABASE_URL=postgresql://eatpulse:changeme@localhost:5432/eatpulse

# Direct Aurora endpoint — used by Alembic migrations (bypasses PgBouncer)
AURORA_DIRECT_URL=postgresql://eatpulse:changeme@localhost:5432/eatpulse

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-32-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── Swiggy MCP ────────────────────────────────────────────────────────────────
SWIGGY_MCP_BASE_URL=https://mcp.swiggy.com/food
SWIGGY_MCP_API_KEY=

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development      # development | production
LOG_LEVEL=INFO
WEBHOOK_BASE_URL=https://dashboard.eatpulse.in
BOT_MODE=polling             # polling (local dev) | webhook (production)

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
# Only needed locally — EC2 uses instance profile
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SECRETS_MANAGER_SECRET_ID=eatpulse/prod
